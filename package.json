{
  "name": "tgsm-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '@tgsm/core' build && bun run --filter '@imadtg/tgsm' build",
    "tgsm": "bun run packages/cli/src/index.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "bun-types": "^1.3.11",
    "tsup": "^8.5.0",
    "typescript": "^5.8.2"
  }
}
